{
  "manifest_version": 3,
  "name": "Dynamics Auto-Refresh",
  "version": "1.0",
  "description": "Automatically click the Refresh button on dynamics.com periodically.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["*://*.dynamics.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Settings"
  },
  "content_scripts": [
    {
      "matches": ["*://*.dynamics.com/*"],
      "js": ["content.js"]
    }
  ]
}
